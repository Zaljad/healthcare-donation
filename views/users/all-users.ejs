<%- include('../partials/header.ejs') %>

<h2>All Users</h2>

<% if (users && users.length > 0) { %>

  <table class="users-table" border="1" cellpadding="8" cellspacing="0">
    <tr>
      <th>Username</th>
      <th>Email</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>

<% users.forEach(user => { %>
  <tr>
    <td><%= user.userName %></td>
    <td><%= user.email %></td>
    <td><%= user.role %></td>
    <td>
      <a href="/users/details/<%= user._id %>">View</a> |
      <a href="/users/delete/<%= user._id %>" onclick="return confirm('Are you sure?')">Delete</a>
    </td>
  </tr>
<% }) %>
  </table>

<% } else { %>

  <p>No users found.</p>
<% } %>

<br>

<a href="/">Back to Home</a>

<%- include('../partials/footer.ejs') %>

