<%- include('../partials/header.ejs') %>

<div class="container">
  <div class="card-info">
    <h2>Edit Profile</h2>

    <form action="/users/edit-profile" method="POST" class="form-card">
      <div class="form-item">
        <label for="userName">Username:</label>
        <input
          type="text"
          id="userName"
          name="userName"
          value="<%= user.userName %>"
          required
        />
      </div>

      <div class="form-item">
        <label for="email">Email:</label>
        <input
          type="email"
          id="email"
          name="email"
          value="<%= user.email %>"
          required
        />
      </div>

      <div class="form-item">
        <label for="phoneNum">Phone Number:</label>
        <input
          type="text"
          id="phoneNum"
          name="phoneNum"
          value="<%= user.phoneNum %>"
        />
      </div>

      <div class="form-item">
        <label for="address">Address:</label>
        <input
          type="text"
          id="address"
          name="address"
          value="<%= user.address %>"
          required
        />
      </div>

      <button type="submit" class="btn-main">Update Profile</button>
      <a href="/users/<%= user._id %>" class="btn-secondary">Back to Profile</a>
    </form>
  </div>
</div>

<%- include('../partials/footer.ejs') %>
