<%- include('../partials/header.ejs') %>

<h2>Edit Profile</h2>

<form action="/users/edit-profile" method="POST">
  <div>
    <label for="userName">Username:</label>
    <input
      type="text"
      id="userName"
      name="userName"
      value="<%= user.userName %>"
      required
    />
  </div>

  <div>
    <label for="email">Email:</label>
    <input
      type="email"
      id="email"
      name="email"
      value="<%= user.email %>"
      required
    />
  </div>

  <div>
    <label for="phoneNum">Phone Number:</label>
    <input
      type="number"
      id="phoneNum"
      name="phoneNum"
      value="<%= user.phoneNum %>"
    />
  </div>

  <div>
    <label for="address">Address:</label>
    <input
      type="text"
      id="address"
      name="address"
      value="<%= user.address %>"
      required
    />
  </div>

  <button type="submit">Update</button>
</form>

<%- include('../partials/footer.ejs') %>
