<%- include('../partials/header') %>

<div class="container">
  <h2>Edit Donation</h2>

  <form action="/donation/<%= donation._id %>/edit?_method=PUT" method="POST">
    <input
      type="text"
      name="equipmentName"
      value="<%= donation.equipment.equipmentName %>"
      placeholder="Name"
    />

    <input
      type="text"
      name="category"
      value="<%= donation.equipment.category %>"
      placeholder="Category"
    />

    <input
      type="text"
      name="equipmentImg"
      value="<%= donation.equipment.equipmentImg %>"
      placeholder="Image URL"
    />

    <textarea name="description"><%= donation.equipment.description %></textarea>

    <input
      type="number"
      name="price"
      value="<%= donation.equipment.price %>"
      placeholder="Price"
    />

    <% if(user && user.role === 'admin'){ %>
      <label>Status:</label>
      <select name="status">
        <option value="pending" <%= donation.status === 'pending' ? 'selected' : '' %>>Pending</option>
        <option value="approved" <%= donation.status === 'approved' ? 'selected' : '' %>>Approved</option>
        <option value="rejected" <%= donation.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
      </select>
    <% } else { %>
      <p>Status: <strong><%= donation.status %></strong></p>
    <% } %>

    <button type="submit" class="btn-main">Update</button>
  </form>
</div>

<%- include('../partials/footer') %>
