<%- include('../partials/header') %>

<div class="container">
  <div class="card-info">
    <h2>Edit Donation</h2>

    <form action="/donation/<%= donation._id %>/edit?_method=PUT" method="POST" class="card-details">

      <label for="equipmentName">Name:</label>
      <input
        type="text"
        id="equipmentName"
        name="equipmentName"
        value="<%= donation.equipment?.equipmentName %>"
        placeholder="Name"
        required
      />

      <div class="form-item">
          <label for="category">Category:</label>
          <select id="category" name="category" required>
            <option value="" display selected>select a category..</option>
            <option value="Mobility">
              Mobility Aids (Crutches, Wheelchairs..)
            </option>
            <option value="Respiratory">Respiratory Devices</option>
            <option value="Monitoring">Monitoring Devices (BP, Glucose)</option>
            <option value="General">General Medical Tools</option>
          </select>
        </div>
    <br><br>

      <label for="equipmentImg">Image URL:</label>
      <input
        type="text"
        id="equipmentImg"
        name="equipmentImg"
        value="<%= donation.equipment?.equipmentImg %>"
        placeholder="Image URL"
      />

      <label for="description">Description:</label>
      <textarea name="description" id="description" rows="4"><%= donation.equipment?.description %></textarea>

      <label for="price">Price:</label>
      <input
        type="number"
        id="price"
        name="price"
        value="<%= donation.equipment?.price %>"
        placeholder="Price"
        required
      />

      <% if(user && user.role === 'admin'){ %>
        <label for="status">Status:</label>
        <select name="status" id="status">
          <option value="pending" <%= donation.status === 'pending' ? 'selected' : '' %>>Pending</option>
          <option value="approved" <%= donation.status === 'approved' ? 'selected' : '' %>>Approved</option>
          <option value="rejected" <%= donation.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
        </select>
      <% } else { %>
        <p>Status: <strong><%= donation.status %></strong></p>
      <% } %>

      <button type="submit" class="btn-main">Update</button>
    </form>

    <a href="/donation/get-all-donations" class="btn-secondary" style="margin-top: 10px;">Back to Donation Details</a>
  </div>
</div>

<%- include('../partials/footer') %>
