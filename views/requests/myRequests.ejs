<%- include('../partials/header.ejs') %>

<div class="container">
  <div class="card-info">
    <h2>My Requests</h2>

    <% if (!requests || requests.length === 0) { %>
      <p>No requests yet.</p>
      <p>
        <a href="/medicalEquipment" class="btn-main">Click here to make a new request</a>
      </p>
    <% } else { %>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Medical Equipment</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% requests.forEach(r => { %>
              <tr>
                <td><%= r.equipment?.equipmentName %></td>
                <td><%= r.status %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <p>
        <a href="/medicalEquipment" class="btn-secondary">Add a new request</a>
      </p>
    <% } %>
  </div>
</div>

<%- include('../partials/footer.ejs') %>
