<%- include('../partials/header.ejs') %>

<h2>All Requests</h2>

<% if (requests.length === 0) { %>
  <p>No requests found.</p>
<% } else { %>
  <table border="1" cellpadding="5" cellspacing="0">
    <tr>
      <th>User</th>
      <th>Email</th>
      <th>Equipment</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>

    <% requests.forEach(r => { %>
      <tr>
        <td><%= r.requestedUser?.userName %></td>
        <td><%= r.requestedUser?.email %></td>
        <td><%= r.equipment?.equipmentName %></td>
        <td><%= r.status %></td>
        <td>
          <form action="/requests/update/<%= r._id %>" method="POST" style="display:inline-block;">
            <select name="status">
              <option value="pending" <%= r.status === 'pending' ? 'selected' : '' %>>Pending</option>
              <option value="approved" <%= r.status === 'approved' ? 'selected' : '' %>>Approved</option>
              <option value="rejected" <%= r.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
            </select>
            <button type="submit">Update</button>
          </form>

          <a href="/requests/delete/<%= r._id %>" onclick="return confirm('Are you sure?')">Delete</a>
        </td>
      </tr>
    <% }) %>
  </table>
<% } %>

<%- include('../partials/footer.ejs') %>
